@page
@model CustomersModel
@{
    ViewData["Title"] = "Customers";
}

<h2><i class="bi bi-people"></i> Customers</h2>
<p class="text-muted">AdventureWorksLT customer directory</p>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Company</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Customers)
            {
                <tr>
                    <td>@c.CustomerId</td>
                    <td><strong>@c.FirstName @c.LastName</strong></td>
                    <td><a href="mailto:@c.Email">@c.Email</a></td>
                    <td>@(c.Company ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<p class="text-muted"><small>Showing @Model.Customers.Count customers</small></p>
