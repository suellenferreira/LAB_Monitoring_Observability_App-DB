@page
@model EmployeesModel
@{
    ViewData["Title"] = "Employees (SQL VM)";
}

<h2><i class="bi bi-person-badge"></i> Employees <span class="badge bg-secondary">SQL VM (IaaS)</span></h2>
<p class="text-muted">AdventureWorks2022 employee data from SQL Server on Azure VM</p>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Job Title</th>
                <th>Department</th>
                <th>Hire Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Employees)
            {
                <tr>
                    <td>@e.EmployeeId</td>
                    <td><strong>@e.FirstName @e.LastName</strong></td>
                    <td>@e.JobTitle</td>
                    <td><span class="badge bg-info text-dark">@e.Department</span></td>
                    <td>@e.HireDate.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<p class="text-muted"><small>Showing @Model.Employees.Count employees from SQL VM</small></p>
