@page
@{
    ViewData["Title"] = "Error";
}
<div class="text-center mt-5">
    <h1 class="display-4 text-danger"><i class="bi bi-exclamation-circle"></i></h1>
    <h2>Something went wrong</h2>
    <p class="text-muted">An unexpected error occurred. Check Application Insights for details.</p>
    <a asp-page="/Index" class="btn btn-primary">Back to Dashboard</a>
</div>
