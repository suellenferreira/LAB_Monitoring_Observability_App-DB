@page
@model ProductsModel
@{
    ViewData["Title"] = "Products";
}

<h2><i class="bi bi-box-seam"></i> Products</h2>
<p class="text-muted">AdventureWorksLT product catalog from Azure SQL Database</p>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Number</th>
                <th>Color</th>
                <th class="text-end">Cost</th>
                <th class="text-end">Price</th>
                <th>Size</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Products)
            {
                <tr>
                    <td>@p.ProductId</td>
                    <td><strong>@p.Name</strong></td>
                    <td><code>@p.ProductNumber</code></td>
                    <td>
                        @if (p.Color != null)
                        {
                            <span class="badge bg-secondary">@p.Color</span>
                        }
                    </td>
                    <td class="text-end">@p.StandardCost.ToString("C")</td>
                    <td class="text-end">@p.ListPrice.ToString("C")</td>
                    <td>@(p.Size ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<p class="text-muted"><small>Showing @Model.Products.Count products</small></p>
